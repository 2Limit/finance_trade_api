# ── Environment ────────────────────────────────────────────
ENV=dev                          # dev | prod

# ── Database ───────────────────────────────────────────────
# dev: SQLite
DB_URL=sqlite+aiosqlite:///./trading.db
# prod: PostgreSQL
# DB_URL=postgresql+asyncpg://trader:trader_pw@localhost:5432/trading

# ── PostgreSQL (docker-compose 전용) ───────────────────────
POSTGRES_USER=trader
POSTGRES_PASSWORD=trader_pw
POSTGRES_DB=trading

# ── Redis ──────────────────────────────────────────────────
# 미설정 시 in-memory fallback
REDIS_URL=redis://localhost:6379/0

# ── Event Bus ─────────────────────────────────────────────
# memory | redis  (REDIS_URL 설정 시 redis 권장)
EVENT_BUS_BACKEND=redis

# ── Upbit ──────────────────────────────────────────────────
UPBIT_ACCESS_KEY=your_upbit_access_key
UPBIT_SECRET_KEY=your_upbit_secret_key
UPBIT_BASE_URL=https://api.upbit.com
UPBIT_WS_URL=wss://api.upbit.com/websocket/v1

# ── Discord ────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Trading ────────────────────────────────────────────────
SYMBOLS=["KRW-BTC","KRW-ETH"]

# ── Risk ───────────────────────────────────────────────────
RISK_MAX_ORDER_KRW=500000        # 단일 주문 최대 금액 (KRW)
RISK_MAX_DAILY_LOSS_KRW=1000000  # 일일 최대 손실 한도 (KRW)
RISK_MAX_POSITION_RATIO=0.3      # 포트폴리오 대비 최대 포지션 비중

# ── Stop-Loss / Take-Profit ────────────────────────────────
STOP_LOSS_PCT=0.05
TAKE_PROFIT_PCT=0.10

# ── Order Deduplication ────────────────────────────────────
ORDER_COOLDOWN_SEC=60

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
